    <string name="brand_theme_mars_relic_title">Reliquia de Marte</string>
    <string name="brand_theme_mars_relic_description">Rojo profundo con pergamino para una estética de archivo ceremonial.</string>
    <string name="brand_theme_mars_relic_accessibility">Tema Reliquia de Marte, rojo profundo con beige pergamino.</string>
    <string name="brand_theme_black_crimson_rite_title">Rito carmesí negro</string>
    <string name="brand_theme_black_crimson_rite_description">Negro hollín y carmesí ritual para una atmósfera severa de santuario mecánico.</string>
    <string name="brand_theme_black_crimson_rite_accessibility">Tema Rito carmesí negro, casi negro con rojo carmesí intenso.</string>
    <string name="brand_theme_xeno_code_title">Código Xeno</string>
    <string name="brand_theme_xeno_code_description">Circuitería de obsidiana y verde neón para un pulso mecánico alienígena.</string>
    <string name="brand_theme_xeno_code_accessibility">Tema Código Xeno, negro musgo oscuro con verde neón y un contorno blanco.</string>
    <string name="brand_theme_scarlet_guard_title">Advertencia de peligro</string>
    <string name="brand_theme_scarlet_guard_description">Gris industrial pálido, naranja rojizo de advertencia y grafito oscuro para un aspecto de alerta mecánica.</string>
    <string name="brand_theme_scarlet_guard_accessibility">Tema Advertencia de peligro, gris pálido con naranja rojizo de advertencia y contorno de grafito oscuro.</string>
    <string name="brand_theme_dynasty_revival_title">Renacer de la Dinastía</string>
    <string name="brand_theme_dynasty_revival_description">Negro de metal funerario con verde reactor clásico para un núcleo dinástico reanimado.</string>
    <string name="brand_theme_dynasty_revival_accessibility">Tema Renacer de la Dinastía, negro metal funerario profundo con verde reactor brillante.</string>
    <string name="brand_theme_sepulcher_cyan_title">Cian sepulcral</string>
    <string name="brand_theme_sepulcher_cyan_description">Acero sepulcral frío con cian verdoso contenido para un resplandor regio y mecánico más sereno.</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">Tema Cian sepulcral, acero frío y oscuro con cian verdoso apagado.</string>
    <string name="brand_theme_tomb_sigil_title">Sigilo funerario</string>
    <string name="brand_theme_tomb_sigil_description">Hierro cálido de cripta y verde de resurgimiento intenso para un emblema ceremonial dinástico.</string>
    <string name="brand_theme_tomb_sigil_accessibility">Tema Sigilo funerario, hierro oscuro de cripta con verde de resurgimiento intenso.</string>
    <string name="brand_theme_ancient_alloy_title">Aleación antigua</string>
    <string name="brand_theme_ancient_alloy_description">Sombras de metal envejecido y turquesa fría para el brillo de una forja sepulcral.</string>
    <string name="brand_theme_ancient_alloy_accessibility">Tema Aleación antigua, gris bronce oscuro con turquesa brillante.</string>
    <string name="brand_theme_immortal_rot_title">Efluencia Tóxica</string>
    <string name="brand_theme_immortal_rot_description">Verde helecho y amarillo citrino crean una paleta Dual-tone húmeda y cubierta de maleza.</string>
    <string name="brand_theme_immortal_rot_accessibility">Tema Efluencia Tóxica, verde helecho con amarillo citrino.</string>
    <string name="brand_theme_plague_mire_title">Ciénaga de Plaga</string>
    <string name="brand_theme_plague_mire_description">Verde negro pantanoso, lima enfermiza y naranja cáustico en una bruma febril de ciénaga.</string>
    <string name="brand_theme_plague_mire_accessibility">Tema Ciénaga de Plaga, verde negro pantanoso con lima enfermiza y contorno naranja cáustico.</string>
    <string name="brand_theme_scarlet_carnage_title">Marfil Empapado de Sangre</string>
    <string name="brand_theme_scarlet_carnage_description">Rojo oscuro y latón forjan una brutal paleta Dual-tone de sangre y metal de guerra.</string>
    <string name="brand_theme_scarlet_carnage_accessibility">Tema Marfil Empapado de Sangre, rojo oscuro con latón dorado oscuro.</string>
    <string name="brand_theme_brass_forge_title">Forja de Latón</string>
    <string name="brand_theme_brass_forge_description">Carmesí casi negro, latón de horno y naranja llama en un fulgor marcial fundido.</string>
    <string name="brand_theme_brass_forge_accessibility">Tema Forja de Latón, carmesí casi negro con latón de horno y contorno naranja llama.</string>
    <string name="brand_theme_exquisite_fall_title">Pesadilla de Terciopelo</string>
    <string name="brand_theme_exquisite_fall_description">Violeta de medianoche y rosa intenso con un contorno melocotón suave crean una paleta Dual-tone decadente de vanidad y sensación.</string>
    <string name="brand_theme_exquisite_fall_accessibility">Tema Pesadilla de Terciopelo, violeta de medianoche con rosa intenso y contorno melocotón suave.</string>
    <string name="brand_theme_ecstatic_rapture_title">Éxtasis Extático</string>
    <string name="brand_theme_ecstatic_rapture_description">Violeta orquídea, rosa rubor y oro radiante en una floración arrebatada de luz.</string>
    <string name="brand_theme_ecstatic_rapture_accessibility">Tema Éxtasis Extático, violeta orquídea con rosa rubor y contorno dorado radiante.</string>
    <string name="brand_theme_labyrinth_of_mutability_title">Abismo Arcano</string>
    <string name="brand_theme_labyrinth_of_mutability_description">Azul marino de medianoche, cian eléctrico y un contorno lavanda forman un laberinto Dual-tone cambiante de fría luz de señal.</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">Tema Abismo Arcano, azul marino de medianoche con cian eléctrico y contorno lavanda.</string>
    <string name="brand_theme_fires_of_fate_title">Fuegos del Destino</string>
    <string name="brand_theme_fires_of_fate_description">Azul fatídico, llama magenta y lima venenosa en un incendio iluminado por presagios.</string>
    <string name="brand_theme_fires_of_fate_accessibility">Tema Fuegos del Destino, azul fatídico con llama magenta y contorno lima venenosa.</string>
