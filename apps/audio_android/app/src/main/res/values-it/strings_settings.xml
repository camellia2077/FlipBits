    <string name="brand_theme_mars_relic_title">Reliquia di Marte</string>
    <string name="brand_theme_mars_relic_description">Rosso intenso abbinato alla pergamena per un’estetica da archivio cerimoniale.</string>
    <string name="brand_theme_mars_relic_accessibility">Tema Reliquia di Marte, rosso intenso con beige pergamena.</string>
    <string name="brand_theme_black_crimson_rite_title">Rito cremisi nero</string>
    <string name="brand_theme_black_crimson_rite_description">Nero fuliggine e cremisi rituale per un’atmosfera severa da santuario meccanico.</string>
    <string name="brand_theme_black_crimson_rite_accessibility">Tema Rito cremisi nero, quasi nero con rosso cremisi vivido.</string>
    <string name="brand_theme_scarlet_guard_title">Guardia scarlatta</string>
    <string name="brand_theme_scarlet_guard_description">Bianco avorio e cremisi sigillato per un tono araldico disciplinato.</string>
    <string name="brand_theme_scarlet_guard_accessibility">Tema Guardia scarlatta, avorio chiaro con rosso scarlatto scuro.</string>
    <string name="brand_theme_dynasty_revival_title">Rinascita della Dinastia</string>
    <string name="brand_theme_dynasty_revival_description">Nero metallo tombale e verde reattore classico per un nucleo dinastico risvegliato.</string>
    <string name="brand_theme_dynasty_revival_accessibility">Tema Rinascita della Dinastia, nero metallo tombale profondo con verde reattore brillante.</string>
    <string name="brand_theme_sepulcher_cyan_title">Ciano sepolcrale</string>
    <string name="brand_theme_sepulcher_cyan_description">Acciaio sepolcrale freddo e ciano verde contenuto per un bagliore meccanico regale più discreto.</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">Tema Ciano sepolcrale, acciaio freddo scuro con ciano verde attenuato.</string>
    <string name="brand_theme_tomb_sigil_title">Sigillo tombale</string>
    <string name="brand_theme_tomb_sigil_description">Ferro di cripta caldo e verde del risveglio vivido per un marchio dinastico cerimoniale.</string>
    <string name="brand_theme_tomb_sigil_accessibility">Tema Sigillo tombale, ferro di cripta scuro con verde del risveglio vivido.</string>
    <string name="brand_theme_ancient_alloy_title">Lega antica</string>
    <string name="brand_theme_ancient_alloy_description">Ombre di metallo consumato e turchese freddo per un bagliore da forgia sepolcrale.</string>
    <string name="brand_theme_ancient_alloy_accessibility">Tema Lega antica, grigio bronzo scuro con turchese brillante.</string>
    <string name="brand_theme_immortal_rot_title">Effluvio Tossico</string>
    <string name="brand_theme_immortal_rot_description">Verde felce e giallo citrino creano una palette Dual-tone umida e invasa.</string>
    <string name="brand_theme_immortal_rot_accessibility">Tema Effluvio Tossico, verde felce con giallo citrino.</string>
    <string name="brand_theme_plague_mire_title">Acquitrino di Peste</string>
    <string name="brand_theme_plague_mire_description">Verde nero di palude, lime malato e arancio caustico in una foschia febbrile.</string>
    <string name="brand_theme_plague_mire_accessibility">Tema Acquitrino di Peste, verde nero di palude con lime malato e contorno arancio caustico.</string>
    <string name="brand_theme_scarlet_carnage_title">Avorio Intriso di Sangue</string>
    <string name="brand_theme_scarlet_carnage_description">Rosso scuro e ottone forgiano una brutale palette Dual-tone di sangue e metallo di guerra.</string>
    <string name="brand_theme_scarlet_carnage_accessibility">Tema Avorio Intriso di Sangue, rosso scuro con ottone dorato scuro.</string>
    <string name="brand_theme_brass_forge_title">Forgia d\'Ottone</string>
    <string name="brand_theme_brass_forge_description">Cremisi quasi nero, ottone da fornace e arancio fiamma in un bagliore marziale fuso.</string>
    <string name="brand_theme_brass_forge_accessibility">Tema Forgia d\'Ottone, cremisi quasi nero con ottone da fornace e contorno arancio fiamma.</string>
    <string name="brand_theme_exquisite_fall_title">Incubo di Velluto</string>
    <string name="brand_theme_exquisite_fall_description">Viola di mezzanotte e rosa acceso con un contorno pesca morbido creano una palette Dual-tone decadente di vanità e sensazione.</string>
    <string name="brand_theme_exquisite_fall_accessibility">Tema Incubo di Velluto, viola di mezzanotte con rosa acceso e contorno pesca morbido.</string>
    <string name="brand_theme_ecstatic_rapture_title">Estasi Radiosa</string>
    <string name="brand_theme_ecstatic_rapture_description">Viola orchidea, rosa cipria e oro radiante in una fioritura ammaliante.</string>
    <string name="brand_theme_ecstatic_rapture_accessibility">Tema Estasi Radiosa, viola orchidea con rosa cipria e contorno oro radiante.</string>
    <string name="brand_theme_labyrinth_of_mutability_title">Abisso Arcano</string>
    <string name="brand_theme_labyrinth_of_mutability_description">Blu navy di mezzanotte, ciano elettrico e contorno lavanda formano un labirinto Dual-tone mutevole di fredda luce di segnale.</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">Tema Abisso Arcano, blu navy di mezzanotte con ciano elettrico e contorno lavanda.</string>
    <string name="brand_theme_fires_of_fate_title">Fuochi del Destino</string>
    <string name="brand_theme_fires_of_fate_description">Blu fatidico, fiamma magenta e lime venefico in un incendio carico di presagi.</string>
    <string name="brand_theme_fires_of_fate_accessibility">Tema Fuochi del Destino, blu fatidico con fiamma magenta e contorno lime venefico.</string>
