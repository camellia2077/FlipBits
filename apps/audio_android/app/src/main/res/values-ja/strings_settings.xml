    <string name="brand_theme_mars_relic_title">マーズレリック</string>
    <string name="brand_theme_mars_relic_description">儀式用保管所のような外見のための、羊皮紙と深い赤の組み合わせ。</string>
    <string name="brand_theme_mars_relic_accessibility">マーズレリック・テーマ。深い赤と羊皮紙のようなベージュ。</string>
    <string name="brand_theme_black_crimson_rite_title">ブラッククリムゾンの儀</string>
    <string name="brand_theme_black_crimson_rite_description">すすのような黒と儀式的な真紅。厳格な機械の祭壇の雰囲気に。</string>
    <string name="brand_theme_black_crimson_rite_accessibility">ブラッククリムゾンの儀テーマ。黒に近い色と鮮やかな真紅。</string>
    <string name="brand_theme_scarlet_guard_title">スカーレットガード</string>
    <string name="brand_theme_scarlet_guard_description">規律ある紋章学的なトーンのための、アイボリーホワイトと封印された真紅。</string>
    <string name="brand_theme_scarlet_guard_accessibility">スカーレットガード・テーマ。明るいアイボリーと濃いスカーレットレッド。</string>
    <string name="brand_theme_dynasty_revival_title">ダイナスティ・リバイバル</string>
    <string name="brand_theme_dynasty_revival_description">再覚醒した王朝の核をイメージした、トゥームメタル・ブラックと伝統的なリアクター・グリーン。</string>
    <string name="brand_theme_dynasty_revival_accessibility">ダイナスティ・リバイバル・テーマ。深いトゥームメタル・ブラックと鮮やかなリアクター・グリーン。</string>
    <string name="brand_theme_sepulcher_cyan_title">セパルカー・シアン</string>
    <string name="brand_theme_sepulcher_cyan_description">静かな王室の機械の輝き。冷たいセパルカースチールと控えめなシアン・グリーン。</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">セパルカー・シアン・テーマ。冷たく暗いスチールと落ち着いたシアン・グリーン。</string>
    <string name="brand_theme_tomb_sigil_title">トゥーム・シジル</string>
    <string name="brand_theme_tomb_sigil_description">儀式的な王朝の印のための、温かみのある地下室の鉄と鋭いリバイバル・グリーン。</string>
    <string name="brand_theme_tomb_sigil_accessibility">トゥーム・シジル・テーマ。暗い地下室の鉄と鮮やかなリバイバル・グリーン。</string>
    <string name="brand_theme_ancient_alloy_title">エンシェント・アロイ</string>
    <string name="brand_theme_ancient_alloy_description">トゥームフォージの輝き。風化した金属の影と冷たいターコイズ。</string>
    <string name="brand_theme_ancient_alloy_accessibility">エンシェント・アロイ・テーマ。ダークブロンズグレーと明るいターコイズ。</string>
    <string name="brand_theme_immortal_rot_title">酸蝕の濁流</string>
    <string name="brand_theme_immortal_rot_description">シダの緑とシトリンイエロー。湿った、生い茂ったデュアルトーンパレット。</string>
    <string name="brand_theme_immortal_rot_accessibility">酸蝕の濁流・テーマ。シダの緑とシトリンイエロー。</string>
    <string name="brand_theme_plague_mire_title">疫の沼</string>
    <string name="brand_theme_plague_mire_description">黒ずんだ沼緑、病んだライム、腐食した橙が熱を帯びた湿地の靄を描く。</string>
    <string name="brand_theme_plague_mire_accessibility">疫の沼テーマ。黒ずんだ沼緑に病んだライム、腐食した橙の輪郭。</string>
    <string name="brand_theme_scarlet_carnage_title">血濡れの象牙</string>
    <string name="brand_theme_scarlet_carnage_description">血と戦争の金属。濃い赤と真鍮色が織りなす冷酷なデュアルトーンパレット。</string>
    <string name="brand_theme_scarlet_carnage_accessibility">血濡れの象牙・テーマ。濃い赤とダークゴールデンロッドの真鍮色。</string>
    <string name="brand_theme_brass_forge_title">黄銅の炉</string>
    <string name="brand_theme_brass_forge_description">ほぼ黒い深紅、炉の黄銅、炎の橙が溶けた戦の輝きを放つ。</string>
    <string name="brand_theme_brass_forge_accessibility">黄銅の炉テーマ。黒に近い深紅に炉の黄銅、炎の橙の輪郭。</string>
    <string name="brand_theme_exquisite_fall_title">ビロードの悪夢</string>
    <string name="brand_theme_exquisite_fall_description">真夜中の紫と鮮烈なピンク、やわらかなピーチ色の縁取りが、虚栄と感覚の退廃的なデュアルトーンを形作ります。</string>
    <string name="brand_theme_exquisite_fall_accessibility">ビロードの悪夢・テーマ。真夜中の紫に鮮烈なピンク、そしてやわらかなピーチ色の縁取り。</string>
    <string name="brand_theme_ecstatic_rapture_title">恍惚の陶酔</string>
    <string name="brand_theme_ecstatic_rapture_description">蘭の紫、頬紅のピンク、輝く金が恍惚の光彩に咲く。</string>
    <string name="brand_theme_ecstatic_rapture_accessibility">恍惚の陶酔テーマ。蘭の紫に頬紅のピンク、輝く金の輪郭。</string>
    <string name="brand_theme_labyrinth_of_mutability_title">秘術の深淵</string>
    <string name="brand_theme_labyrinth_of_mutability_description">真夜中のネイビー、エレクトリックシアン、そしてラベンダーの縁取りが、冷たい信号光の揺らぐデュアルトーン迷宮を形作ります。</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">秘術の深淵・テーマ。真夜中のネイビーにエレクトリックシアン、そしてラベンダーの縁取り。</string>
    <string name="brand_theme_fires_of_fate_title">宿命の火</string>
    <string name="brand_theme_fires_of_fate_description">宿命の青炎、マゼンタの火、毒めいたライムが凶兆の輝きに燃える。</string>
    <string name="brand_theme_fires_of_fate_accessibility">宿命の火テーマ。宿命の青炎にマゼンタの火、毒めいたライムの輪郭。</string>
    <string name="brand_theme_custom_title">カスタム・デュアルトーン</string>
    <string name="brand_theme_custom_description">自分のデュアルトーン色を使い、サンプルテキストは神聖なる機械をそのまま使います。</string>
    <string name="brand_theme_custom_accessibility">カスタム・デュアルトーンテーマのプレビュー。</string>
