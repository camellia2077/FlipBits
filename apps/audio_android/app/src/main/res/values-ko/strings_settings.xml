    <string name="brand_theme_scarlet_guard_accessibility">스칼렛 가드 테마, 밝은 아이보리와 어두운 스칼렛 레드.</string>
    <string name="brand_theme_dynasty_revival_title">다이너스티 리바이벌</string>
    <string name="brand_theme_dynasty_revival_description">되살아난 왕조를 떠올리게 하는 툼 메탈 블랙과 리액터 그린.</string>
    <string name="brand_theme_dynasty_revival_accessibility">다이너스티 리바이벌 테마, 깊은 툼 메탈 블랙과 밝은 리액터 그린.</string>
    <string name="brand_theme_sepulcher_cyan_title">세펄커 시안</string>
    <string name="brand_theme_sepulcher_cyan_description">고요한 왕실 광채를 띠는 차가운 세펄커 스틸과 절제된 시안 그린.</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">세펄커 시안 테마, 차갑고 어두운 스틸과 차분한 시안 그린.</string>
    <string name="brand_theme_tomb_sigil_title">툼 시질</string>
    <string name="brand_theme_tomb_sigil_description">의식적인 왕조의 문장을 위한 따뜻한 지하실 철색과 선명한 리바이벌 그린.</string>
    <string name="brand_theme_tomb_sigil_accessibility">툼 시질 테마, 어두운 지하실 철색과 선명한 리바이벌 그린.</string>
    <string name="brand_theme_ancient_alloy_title">고대 합금</string>
    <string name="brand_theme_ancient_alloy_description">툼 포지의 빛을 띠는 풍화된 금속빛과 차가운 터콰이즈.</string>
    <string name="brand_theme_ancient_alloy_accessibility">고대 합금 테마, 어두운 브론즈 그레이와 밝은 터콰이즈.</string>
    <string name="brand_theme_immortal_rot_title">산식 탁류</string>
    <string name="brand_theme_immortal_rot_description">습하고 무성한 기운의 고사리 그린과 시트린 옐로우.</string>
    <string name="brand_theme_immortal_rot_accessibility">산식 탁류 테마, 고사리 그린과 시트린 옐로우.</string>
    <string name="brand_theme_plague_mire_title">역병 늪</string>
    <string name="brand_theme_plague_mire_description">열병 같은 늪 안개를 띠는 늪빛 흑록, 병든 라임, 부식빛 오렌지 윤곽.</string>
    <string name="brand_theme_plague_mire_accessibility">역병 늪 테마, 늪빛 흑록과 병든 라임, 부식빛 오렌지 윤곽.</string>
    <string name="brand_theme_scarlet_carnage_title">피에 젖은 상아</string>
    <string name="brand_theme_scarlet_carnage_description">엄정한 전장의 기운을 띠는 짙은 붉은색과 황동색.</string>
    <string name="brand_theme_scarlet_carnage_accessibility">피에 젖은 상아 테마, 짙은 빨간색과 어두운 골든로드 황동색.</string>
    <string name="brand_theme_brass_forge_title">황동 용광로</string>
    <string name="brand_theme_brass_forge_description">녹아드는 전장의 열기를 띠는 흑적색, 화로빛 황동, 불꽃빛 오렌지 윤곽.</string>
    <string name="brand_theme_brass_forge_accessibility">황동 용광로 테마, 흑적색과 화로빛 황동, 불꽃빛 오렌지 윤곽.</string>
    <string name="brand_theme_exquisite_fall_title">벨벳 악몽</string>
    <string name="brand_theme_exquisite_fall_description">나른한 퇴폐미를 띠는 한밤의 보라, 선명한 핑크, 부드러운 피치 윤곽.</string>
    <string name="brand_theme_exquisite_fall_accessibility">벨벳 악몽 테마, 한밤의 보라와 강렬한 핑크, 그리고 부드러운 피치색 윤곽.</string>
    <string name="brand_theme_ecstatic_rapture_title">황홀한 도취</string>
    <string name="brand_theme_ecstatic_rapture_description">황홀한 개화를 띠는 오키드 바이올렛, 블러시 핑크, 찬란한 골드 윤곽.</string>
    <string name="brand_theme_ecstatic_rapture_accessibility">황홀한 도취 테마, 오키드 바이올렛과 블러시 핑크, 찬란한 골드 윤곽.</string>
    <string name="brand_theme_labyrinth_of_mutability_title">비전의 심연</string>
    <string name="brand_theme_labyrinth_of_mutability_description">차가운 빛의 미로를 띠는 한밤의 네이비, 전기빛 시안, 라벤더 윤곽.</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">비전의 심연 테마, 한밤의 네이비와 전기빛 시안, 라벤더 윤곽.</string>
    <string name="brand_theme_fires_of_fate_title">운명의 불꽃</string>
    <string name="brand_theme_fires_of_fate_description">불길한 광채를 띠는 페이트파이어 블루, 마젠타 불꽃, 베놈 라임 윤곽.</string>
    <string name="brand_theme_fires_of_fate_accessibility">운명의 불꽃 테마, 페이트파이어 블루와 마젠타 불꽃, 베놈 라임 윤곽.</string>
