    <string name="brand_theme_mars_relic_title">Relikt Marsa</string>
    <string name="brand_theme_mars_relic_description">Głęboka czerwień z pergaminem nadaje ceremonialny archiwalny wygląd.</string>
    <string name="brand_theme_mars_relic_accessibility">Motyw Relikt Marsa, głęboka czerwień z pergaminowym beżem.</string>
    <string name="brand_theme_black_crimson_rite_title">Czarny Karmazynowy Ryt</string>
    <string name="brand_theme_black_crimson_rite_description">Sadza i rytualny karmazyn budują surowy nastrój maszynowego sanktuarium.</string>
    <string name="brand_theme_black_crimson_rite_accessibility">Motyw Czarny Karmazynowy Ryt, prawie czarny z intensywną karmazynową czerwienią.</string>
    <string name="brand_theme_xeno_code_title">Ksenokod</string>
    <string name="brand_theme_xeno_code_description">Obsydianowe obwody i neonowa zieleń tworzą puls obcej maszyny.</string>
    <string name="brand_theme_xeno_code_accessibility">Motyw Ksenokod, ciemna mszysta czerń z neonową zielenią i białym obrysem.</string>
    <string name="brand_theme_scarlet_guard_title">Ostrzeżenie o zagrożeniu</string>
    <string name="brand_theme_scarlet_guard_description">Jasna przemysłowa szarość, ostrzegawczy pomarańczowoczerwony i ciemny grafit tworzą wygląd mechanicznego alarmu.</string>
    <string name="brand_theme_scarlet_guard_accessibility">Motyw Ostrzeżenie o zagrożeniu, blada szarość z ostrzegawczą pomarańczową czerwienią i ciemnym grafitowym obrysem.</string>
    <string name="brand_theme_dynasty_revival_title">Odrodzenie Dynastii</string>
    <string name="brand_theme_dynasty_revival_description">Czarny metal grobowca i klasyczna reaktorowa zieleń dla rdzenia przebudzonej dynastii.</string>
    <string name="brand_theme_dynasty_revival_accessibility">Motyw Odrodzenie Dynastii, głęboka czerń grobowego metalu z jasną reaktorową zielenią.</string>
    <string name="brand_theme_sepulcher_cyan_title">Grobowy Cyjan</string>
    <string name="brand_theme_sepulcher_cyan_description">Chłodna stal grobowca i stonowana zieleń cyjanowa dają cichszy królewski blask maszyny.</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">Motyw Grobowy Cyjan, chłodna ciemna stal ze stonowaną zielenią cyjanową.</string>
    <string name="brand_theme_tomb_sigil_title">Sigil Grobowca</string>
    <string name="brand_theme_tomb_sigil_description">Ciepłe żelazo krypty i ostra zieleń odrodzenia dla ceremonialnego znaku dynastii.</string>
    <string name="brand_theme_tomb_sigil_accessibility">Motyw Sigil Grobowca, ciemne żelazo krypty z żywą zielenią odrodzenia.</string>
    <string name="brand_theme_ancient_alloy_title">Starożytny Stop</string>
    <string name="brand_theme_ancient_alloy_description">Cienie zwietrzałego metalu i chłodny turkus tworzą blask grobowej kuźni.</string>
    <string name="brand_theme_ancient_alloy_accessibility">Motyw Starożytny Stop, ciemny brązowoszary z jasnym turkusem.</string>
    <string name="brand_theme_immortal_rot_title">Toksyczny Wyciek</string>
    <string name="brand_theme_immortal_rot_description">Zieleń paproci i cytrynowy żółty tworzą wilgotną, zarośniętą paletę dual-tone.</string>
    <string name="brand_theme_immortal_rot_accessibility">Motyw Toksyczny Wyciek, zieleń paproci z cytrynowym żółtym.</string>
    <string name="brand_theme_plague_mire_title">Morowe Rozlewisko</string>
    <string name="brand_theme_plague_mire_description">Bagienna czerń zieleni, chorobliwa limonka i żrący pomarańcz toną w gorączkowej mgle mokradeł.</string>
    <string name="brand_theme_plague_mire_accessibility">Motyw Morowe Rozlewisko, bagienna czerń zieleni z chorobliwą limonką i żrącym pomarańczowym obrysem.</string>
    <string name="brand_theme_scarlet_carnage_title">Krwią Przesiąknięta Kość Słoniowa</string>
    <string name="brand_theme_scarlet_carnage_description">Ciemna czerwień i mosiądz kują brutalną paletę dual-tone krwi i wojennego metalu.</string>
    <string name="brand_theme_scarlet_carnage_accessibility">Motyw Krwią Przesiąknięta Kość Słoniowa, ciemna czerwień z ciemnym złotym mosiądzem.</string>
    <string name="brand_theme_brass_forge_title">Mosiężna Kuźnia</string>
    <string name="brand_theme_brass_forge_description">Karmazyn niemal czarny, piecowy mosiądz i płomienny pomarańcz żarzą się wojennym blaskiem.</string>
    <string name="brand_theme_brass_forge_accessibility">Motyw Mosiężna Kuźnia, niemal czarny karmazyn z piecowym mosiądzem i płomiennym pomarańczowym obrysem.</string>
    <string name="brand_theme_exquisite_fall_title">Aksamitny Koszmar</string>
    <string name="brand_theme_exquisite_fall_description">Północny fiolet i intensywny róż z miękkim brzoskwiniowym obrysem tworzą dekadencką paletę dual-tone próżności i doznań.</string>
    <string name="brand_theme_exquisite_fall_accessibility">Motyw Aksamitny Koszmar, północny fiolet z intensywnym różem i miękkim brzoskwiniowym obrysem.</string>
    <string name="brand_theme_ecstatic_rapture_title">Ekstatyczny Zachwyt</string>
    <string name="brand_theme_ecstatic_rapture_description">Orchideowy fiolet, pudrowy róż i promienne złoto rozkwitają w uwodzicielskim blasku.</string>
    <string name="brand_theme_ecstatic_rapture_accessibility">Motyw Ekstatyczny Zachwyt, orchideowy fiolet z pudrowym różem i promiennym złotym obrysem.</string>
    <string name="brand_theme_labyrinth_of_mutability_title">Arkaniczna Otchłań</string>
    <string name="brand_theme_labyrinth_of_mutability_description">Granat północy, elektryczny cyjan i lawendowy obrys tworzą zmienny labirynt dual-tone z chłodnego światła sygnałowego.</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">Motyw Arkaniczna Otchłań, granat północy z elektrycznym cyjanem i lawendowym obrysem.</string>
    <string name="brand_theme_fires_of_fate_title">Ognie Losu</string>
    <string name="brand_theme_fires_of_fate_description">Błękit przeznaczenia, magentowy płomień i jadowita limonka płoną w blasku złych omenów.</string>
    <string name="brand_theme_fires_of_fate_accessibility">Motyw Ognie Losu, błękit przeznaczenia z magentowym płomieniem i jadowicie limonkowym obrysem.</string>
