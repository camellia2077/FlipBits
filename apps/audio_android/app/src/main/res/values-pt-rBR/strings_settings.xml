    <string name="brand_theme_mars_relic_title">Relíquia de Marte</string>
    <string name="brand_theme_mars_relic_description">Vermelho profundo com pergaminho para um visual cerimonial de arquivo.</string>
    <string name="brand_theme_mars_relic_accessibility">Tema Relíquia de Marte, vermelho profundo com bege pergaminho.</string>
    <string name="brand_theme_black_crimson_rite_title">Rito Negro Carmesim</string>
    <string name="brand_theme_black_crimson_rite_description">Preto fuligem e carmesim ritual para um clima severo de santuário mecânico.</string>
    <string name="brand_theme_black_crimson_rite_accessibility">Tema Rito Negro Carmesim, quase preto com vermelho carmesim vivo.</string>
    <string name="brand_theme_scarlet_guard_title">Guarda Escarlate</string>
    <string name="brand_theme_scarlet_guard_description">Branco marfim e carmesim selado para um tom heráldico disciplinado.</string>
    <string name="brand_theme_scarlet_guard_accessibility">Tema Guarda Escarlate, marfim claro com vermelho escarlate escuro.</string>
    <string name="brand_theme_dynasty_revival_title">Renascimento da Dinastia</string>
    <string name="brand_theme_dynasty_revival_description">Preto de metal tumular com verde reator clássico para o núcleo de uma dinastia desperta.</string>
    <string name="brand_theme_dynasty_revival_accessibility">Tema Renascimento da Dinastia, preto profundo de metal tumular com verde reator brilhante.</string>
    <string name="brand_theme_sepulcher_cyan_title">Ciano Sepulcral</string>
    <string name="brand_theme_sepulcher_cyan_description">Aço sepulcral frio com verde ciano contido para um brilho mecânico régio mais discreto.</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">Tema Ciano Sepulcral, aço escuro frio com verde ciano suave.</string>
    <string name="brand_theme_tomb_sigil_title">Sigilo da Tumba</string>
    <string name="brand_theme_tomb_sigil_description">Ferro de cripta quente e verde de renascimento intenso para uma marca cerimonial de dinastia.</string>
    <string name="brand_theme_tomb_sigil_accessibility">Tema Sigilo da Tumba, ferro escuro de cripta com verde de renascimento vivo.</string>
    <string name="brand_theme_ancient_alloy_title">Liga Ancestral</string>
    <string name="brand_theme_ancient_alloy_description">Sombras de metal gasto e turquesa fria para um brilho de forja tumular.</string>
    <string name="brand_theme_ancient_alloy_accessibility">Tema Liga Ancestral, cinza bronze escuro com turquesa brilhante.</string>
    <string name="brand_theme_immortal_rot_title">Eflúvio Tóxico</string>
    <string name="brand_theme_immortal_rot_description">Verde samambaia e amarelo citrino criam uma paleta dual-tone úmida e tomada pela vegetação.</string>
    <string name="brand_theme_immortal_rot_accessibility">Tema Eflúvio Tóxico, verde samambaia com amarelo citrino.</string>
    <string name="brand_theme_plague_mire_title">Pântano Pestilento</string>
    <string name="brand_theme_plague_mire_description">Verde negro de brejo, lima doentia e contorno laranja cáustico num lodo febril.</string>
    <string name="brand_theme_plague_mire_accessibility">Tema Pântano Pestilento, verde negro de brejo com lima doentia e contorno laranja cáustico.</string>
    <string name="brand_theme_scarlet_carnage_title">Marfim Encharcado de Sangue</string>
    <string name="brand_theme_scarlet_carnage_description">Vermelho escuro e latão forjam uma paleta dual-tone brutal de sangue e metal de guerra.</string>
    <string name="brand_theme_scarlet_carnage_accessibility">Tema Marfim Encharcado de Sangue, vermelho escuro com latão dourado escuro.</string>
    <string name="brand_theme_brass_forge_title">Forja de Latão</string>
    <string name="brand_theme_brass_forge_description">Carmesim quase negro, latão de fornalha e contorno laranja em chama num brilho marcial.</string>
    <string name="brand_theme_brass_forge_accessibility">Tema Forja de Latão, carmesim quase negro com latão de fornalha e contorno laranja em chama.</string>
    <string name="brand_theme_exquisite_fall_title">Pesadelo de Veludo</string>
    <string name="brand_theme_exquisite_fall_description">Roxo de meia-noite e rosa intenso com um contorno pêssego suave criam uma paleta dual-tone decadente de vaidade e sensação.</string>
    <string name="brand_theme_exquisite_fall_accessibility">Tema Pesadelo de Veludo, roxo de meia-noite com rosa intenso e contorno pêssego suave.</string>
    <string name="brand_theme_ecstatic_rapture_title">Êxtase Radiante</string>
    <string name="brand_theme_ecstatic_rapture_description">Violeta orquídea, rosa ruborizado e contorno dourado radiante em uma floração decadente.</string>
    <string name="brand_theme_ecstatic_rapture_accessibility">Tema Êxtase Radiante, violeta orquídea com rosa ruborizado e contorno dourado radiante.</string>
    <string name="brand_theme_labyrinth_of_mutability_title">Abismo Arcano</string>
    <string name="brand_theme_labyrinth_of_mutability_description">Azul-marinho de meia-noite, ciano elétrico e um contorno lavanda formam um labirinto dual-tone mutável de luz de sinal fria.</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">Tema Abismo Arcano, azul-marinho de meia-noite com ciano elétrico e contorno lavanda.</string>
    <string name="brand_theme_fires_of_fate_title">Fogos do Destino</string>
    <string name="brand_theme_fires_of_fate_description">Azul do destino, chama magenta e contorno lima venenosa num fogo de maus presságios.</string>
    <string name="brand_theme_fires_of_fate_accessibility">Tema Fogos do Destino, azul do destino com chama magenta e contorno lima venenosa.</string>
