    <string name="brand_theme_mars_relic_title">Марсианская реликвия</string>
    <string name="brand_theme_mars_relic_description">Глубокий красный с пергаментным оттенком создают образ церемониального архива.</string>
    <string name="brand_theme_mars_relic_accessibility">Тема Марсианская реликвия, глубокий красный с пергаментно-бежевым.</string>
    <string name="brand_theme_black_crimson_rite_title">Чёрный Багряный Обряд</string>
    <string name="brand_theme_black_crimson_rite_description">Сажисто-чёрный и ритуальный багряный создают суровую атмосферу машинного святилища.</string>
    <string name="brand_theme_black_crimson_rite_accessibility">Тема Чёрный Багряный Обряд, почти чёрный с ярким багряно-красным.</string>
    <string name="brand_theme_scarlet_guard_title">Багряная Стража</string>
    <string name="brand_theme_scarlet_guard_description">Слоновая кость и запечатанный багряный придают строгий геральдический тон.</string>
    <string name="brand_theme_scarlet_guard_accessibility">Тема Багряная Стража, светлая слоновая кость с тёмно-багряным красным.</string>
    <string name="brand_theme_dynasty_revival_title">Возрождение Династии</string>
    <string name="brand_theme_dynasty_revival_description">Чёрный гробовой металл и классический реакторный зелёный для пробудившегося династического ядра.</string>
    <string name="brand_theme_dynasty_revival_accessibility">Тема Возрождение Династии, глубокий чёрный гробовой металл с ярким реакторным зелёным.</string>
    <string name="brand_theme_sepulcher_cyan_title">Склеповый Циан</string>
    <string name="brand_theme_sepulcher_cyan_description">Холодная склеповая сталь и сдержанный циан-зелёный создают более тихое королевское машинное сияние.</string>
    <string name="brand_theme_sepulcher_cyan_accessibility">Тема Склеповый Циан, холодная тёмная сталь с приглушённым циан-зелёным.</string>
    <string name="brand_theme_tomb_sigil_title">Могильная Печать</string>
    <string name="brand_theme_tomb_sigil_description">Тёплое криптовое железо и яркий зелёный пробуждения создают церемониальный знак династии.</string>
    <string name="brand_theme_tomb_sigil_accessibility">Тема Могильная Печать, тёмное криптовое железо с ярким зелёным пробуждения.</string>
    <string name="brand_theme_ancient_alloy_title">Древний Сплав</string>
    <string name="brand_theme_ancient_alloy_description">Тени потёртого металла и холодная бирюза создают свечение погребальной кузницы.</string>
    <string name="brand_theme_ancient_alloy_accessibility">Тема Древний Сплав, тёмный бронзово-серый с яркой бирюзой.</string>
    <string name="brand_theme_immortal_rot_title">Токсичные Стоки</string>
    <string name="brand_theme_immortal_rot_description">Папоротниковый зелёный и цитриновый жёлтый создают влажную заросшую палитру Dual-tone.</string>
    <string name="brand_theme_immortal_rot_accessibility">Тема Токсичные Стоки, папоротниковый зелёный с цитриновым жёлтым.</string>
    <string name="brand_theme_plague_mire_title">Plague Mire</string>
    <string name="brand_theme_plague_mire_description">Bog-black green, sickly lime, and a caustic orange outline churn into a plague-soaked dual-tone mire.</string>
    <string name="brand_theme_plague_mire_accessibility">Plague Mire theme, bog-black green with sickly lime and a caustic orange outline.</string>
    <string name="brand_theme_scarlet_carnage_title">Окровавленная Слоновая Кость</string>
    <string name="brand_theme_scarlet_carnage_description">Тёмно-красный и латунь формируют жестокую палитру Dual-tone из крови и военного металла.</string>
    <string name="brand_theme_scarlet_carnage_accessibility">Тема Окровавленная Слоновая Кость, тёмно-красный с тёмной латунной позолотой.</string>
    <string name="brand_theme_brass_forge_title">Brass Forge</string>
    <string name="brand_theme_brass_forge_description">Near-black crimson, furnace brass, and a flame-orange outline cast a molten dual-tone forge of war metal.</string>
    <string name="brand_theme_brass_forge_accessibility">Brass Forge theme, near-black crimson with furnace brass and a flame-orange outline.</string>
    <string name="brand_theme_exquisite_fall_title">Бархатный Кошмар</string>
    <string name="brand_theme_exquisite_fall_description">Полуночный фиолетовый и яркий розовый с мягкой персиковой обводкой создают декадентскую палитру Dual-tone тщеславия и чувственности.</string>
    <string name="brand_theme_exquisite_fall_accessibility">Тема Бархатный Кошмар, полуночный фиолетовый с ярким розовым и мягкой персиковой обводкой.</string>
    <string name="brand_theme_ecstatic_rapture_title">Ecstatic Rapture</string>
    <string name="brand_theme_ecstatic_rapture_description">Orchid violet, blush pink, and a radiant gold outline bloom into a euphoric dual-tone fever dream.</string>
    <string name="brand_theme_ecstatic_rapture_accessibility">Ecstatic Rapture theme, orchid violet with blush pink and a radiant gold outline.</string>
    <string name="brand_theme_labyrinth_of_mutability_title">Тайная Бездна</string>
    <string name="brand_theme_labyrinth_of_mutability_description">Полуночный тёмно-синий, электрический циан и лавандовая обводка образуют изменчивый Dual-tone лабиринт холодного сигнального света.</string>
    <string name="brand_theme_labyrinth_of_mutability_accessibility">Тема Тайная Бездна, полуночный тёмно-синий с электрическим цианом и лавандовой обводкой.</string>
    <string name="brand_theme_fires_of_fate_title">Fires of Fate</string>
    <string name="brand_theme_fires_of_fate_description">Fatefire blue, magenta flame, and a venom-lime outline ignite an omen-lit dual-tone blaze.</string>
    <string name="brand_theme_fires_of_fate_accessibility">Fires of Fate theme, fatefire blue with magenta flame and a venom-lime outline.</string>
